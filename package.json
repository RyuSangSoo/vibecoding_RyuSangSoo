{
  "name": "kinelab",
  "private": true,
  "version": "0.1.0",
  "description": "Windows-first educational manipulator simulator draft for DH parameters and forward kinematics.",
  "author": "OpenAI Codex",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "desktop": "electron .",
    "icon:generate": "powershell -ExecutionPolicy Bypass -File .\\scripts\\generate-icon.ps1",
    "dist:win": "npm run build && electron-builder --win portable nsis"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.kinelab.desktop",
    "productName": "KineLab",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "assets/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "KineLab-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KineLab"
    },
    "portable": {
      "artifactName": "KineLab-Portable-${version}.${ext}"
    }
  }
}
